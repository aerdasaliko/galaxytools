<tool id="dnabert2" name="DNABERT-2" version="0.1.0+galaxy0" python_template_version="3.5" profile="21.05">
    <requirements>
        <requirement type="package" version="2.7">pytorch</requirement>
        <requirement type="package" version="5.10.2">transformers</requirement>
        <requirement type="package" version="2.2.6">numpy</requirement>
    </requirements>

    <command detect_errors="exit_code"><![CDATA[
mkdir -p results;

#if $tasks.selected_task == "finetune"
    bash '$__tool_directory__/run_finetuning.sh' \
        "$tasks.train_dataset" \
        "$tasks.dev_dataset" \
        "$tasks.test_dataset" \
        "$tasks.training_params.model_max_length" \
        "$tasks.training_params.batch_train" \
        "$tasks.training_params.batch_eval" \
        "$tasks.training_params.grad_acc" \
        "$tasks.training_params.lr" \
        "$tasks.training_params.epochs" \
        "$tasks.training_params.save_steps" \
        "$tasks.training_params.eval_steps" \
        "$tasks.training_params.warmup_steps" \
        "$tasks.training_params.logging_steps" \
        "$tasks.problem_type" \
        "$selected_model" \
        #if $tasks.lora_section.use_lora == "true"
            "true" \
            "$tasks.lora_section.lora_r" \
            "$tasks.lora_section.lora_alpha" \
            "$tasks.lora_section.lora_dropout"
        #else
            "false"
        #end if

    #if $tasks.save_model == "true"
        zip -r results/model.zip results/model
    #end if

#elif $tasks.selected_task == "embed"
    python '$__tool_directory__/embed_sequence.py' \
        --model "$selected_model" \
        --fasta "$tasks.fasta_file" \
        --batch_size "$tasks.batch_size" \
        --pooling "$tasks.pooling" \
        --output results/embeddings.csv
#else
    echo "Unknown task: $tasks.selected_task"
    exit 1
#end if
    ]]></command>

    <inputs>
        <param name="selected_model" type="select" label="Select model">
            <options from_data_table="huggingface">
                <column name="name" index="1"/>
                <column name="value" index="6"/>
                <filter type="static_value" value="dnabert" column="4"/>
                <filter type="static_value" value="1" column="5"/>
            </options>
            <validator type="no_options" message="No pretrained DNABERT models are installed on this Galaxy instance."/>
        </param>

        <conditional name="tasks">
            <param name="selected_task" type="select" multiple="false" label="Select a task">
                <option value="embed" selected="true">Produce an Embedding</option>
                <option value="finetune">Fine-tune</option>
            </param>

            <when value="embed">
                <param name="fasta_file" type="data" format="fasta"
                       label="Input"
                       help="FASTA file containing sequences to embed."/>
                <param name="pooling" type="select" label="Pooling strategy" help="How embeddings are aggregated.">
                    <option value="mean" selected="true">mean</option>
                    <option value="max">max</option>
                </param>
                <param name="batch_size" type="integer" value="4" min="1" label="Batch size"/>
            </when>

            <when value="finetune">
                <param name="problem_type" type="select" label="Problem type">
                    <option value="classification" selected="true">Classification</option>
                    <option value="regression">Regression</option>
                </param>

                <param name="train_dataset" type="data" format="csv" label="Training dataset"/>
                <param name="dev_dataset" type="data" format="csv" label="Validation dataset"/>
                <param name="test_dataset" type="data" format="csv" label="Test dataset"/>

                <section name="training_params" title="Training parameters" expanded="true">
                    <param name="model_max_length" type="integer" value="128" label="Model max length"/>
                    <param name="batch_train" type="integer" value="8" label="Train batch size"/>
                    <param name="batch_eval" type="integer" value="8" label="Eval batch size"/>
                    <param name="grad_acc" type="integer" value="1" label="Gradient accumulation steps"/>
                    <param name="lr" type="float" value="5e-5" label="Learning rate"/>
                    <param name="epochs" type="integer" value="3" label="Number of epochs"/>
                    <param name="save_steps" type="integer" value="500" label="Save steps"/>
                    <param name="eval_steps" type="integer" value="500" label="Eval steps"/>
                    <param name="warmup_steps" type="integer" value="0" label="Warmup steps"/>
                    <param name="logging_steps" type="integer" value="100" label="Logging steps"/>
                </section>

                <param name="save_model" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Save model"/>

                <conditional name="lora_section">
                    <param name="use_lora" type="boolean" truevalue="true" falsevalue="false" checked="false" label="Use LoRA"/>
                    <when value="true">
                        <param name="lora_r" type="integer" value="8" label="LoRA rank (r)"/>
                        <param name="lora_alpha" type="integer" value="16" label="LoRA alpha"/>
                        <param name="lora_dropout" type="float" value="0.1" label="LoRA dropout"/>
                    </when>
                    <when value="false"/>
                </conditional>
            </when>
        </conditional>
    </inputs>

    <outputs>
        <data name="embeddings_csv"
              format="csv"
              from_work_dir="results/embeddings.csv"
              label="Generated embeddings">
            <filter>tasks['selected_task'] == "embed"</filter>
        </data>

        <data name="trained_model"
              format="zip"
              from_work_dir="results/model.zip"
              label="Fine-tuned model">
            <filter>tasks['selected_task'] == "finetune"</filter>
            <filter>tasks['save_model'] == "true"</filter>
        </data>

        <data name="eval_metrics"
              format="json"
              from_work_dir="results/evaluation.json"
              label="Evaluation metrics">
            <filter>tasks['selected_task'] == "finetune"</filter>
        </data>

        <data name="labels_preds"
              format="csv"
              from_work_dir="results/labels.csv"
              label="Labels and predictions">
            <filter>tasks['selected_task'] == "finetune"</filter>
        </data>
    </outputs>

    <help>
        **What it does**
        
        - **Embed**: Generates sequence embeddings from a FASTA file.
        - **Fine-tune**: Trains DNABERT-2 on CSV datasets for classification/regression.
    </help>

    <citations>
        <citation type="bibtex">
@misc{zhou2024dnabert2efficientfoundationmodel,
  title={DNABERT-2: Efficient Foundation Model and Benchmark For Multi-Species Genome},
  author={Zhihan Zhou and Yanrong Ji and Weijian Li and Pratik Dutta and Ramana Davuluri and Han Liu},
  year={2024},
  eprint={2306.15006},
  archivePrefix={arXiv},
  primaryClass={q-bio.GN},
  url={https://arxiv.org/abs/2306.15006}
}
        </citation>
    </citations>
</tool>